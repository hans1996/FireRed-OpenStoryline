# Copy this file to `.env` for local development overrides.
# Leave unused values blank.

# Optional: point the app at a non-default config file.
OPENSTORYLINE_CONFIG=config.toml

# Optional: override the default built-in LLM/VLM model settings when config.toml
# does not provide a complete model/base_url/api_key triplet.
OPENSTORYLINE_LLM_MODEL=
OPENSTORYLINE_LLM_BASE_URL=
OPENSTORYLINE_LLM_API_KEY=
OPENSTORYLINE_VLM_MODEL=
OPENSTORYLINE_VLM_BASE_URL=
OPENSTORYLINE_VLM_API_KEY=

# Optional: API key for Gemini alternatives that reference GEMINI_API_KEY in config.toml.
GEMINI_API_KEY=

# Optional: media search provider key.
PEXELS_API_KEY=

# Optional: explicit ffmpeg binary path if ffmpeg is not already on PATH.
FFMPEG_BIN=ffmpeg

# Optional: trust X-Forwarded-For / X-Real-IP headers for rate limiting behind a proxy.
RATE_LIMIT_TRUST_PROXY_HEADERS=0
